// Niri scrollable-tiling Wayland compositor configuration
// DankMaterialShell (dms) provides the full desktop shell experience:
// panels, launcher, notifications, theming, lock screen, and media controls.
// Reference: https://github.com/YaLTeR/niri/wiki

// Export Wayland-compatibility environment variables into the session.
environment {
    XDG_CURRENT_DESKTOP "niri"
    QT_QPA_PLATFORM "wayland"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    QT_QPA_PLATFORMTHEME "gtk3"
}

// DankMaterialShell is started via systemd:
//   /usr/lib/systemd/user/niri.service.wants/dms.service -> ../dms.service
// This ensures DMS starts/stops with the niri session and dms ipc works reliably.
// Do NOT add spawn-at-startup for dms here — that would start a second instance.

// DMS manages these config fragments; they are auto-populated on first run.
// The placeholder files must exist before niri starts — see the user-setup hook.
include "dms/colors.kdl"
include "dms/layout.kdl"
include "dms/alttab.kdl"
include "dms/binds.kdl"

input {
    keyboard {
        xkb { }
    }

    touchpad {
        tap
        natural-scroll
    }
}

// Round window corners to match the DMS Material Design theme.
window-rule {
    geometry-corner-radius 12
    clip-to-geometry true
}

// Binds not covered by dms/binds.kdl.
// Everything else (window management, workspaces, DMS IPC, media keys)
// is defined in dms/binds.kdl above.
binds {
    // Additional terminal alias (Mod+T is in dms/binds.kdl)
    Mod+Return { spawn "ptyxis"; }

    // File manager — Dolphin on KDE variant, Nautilus on GNOME variant
    Mod+E { spawn "bash" "-c" "dolphin 2>/dev/null || nautilus"; }
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"
